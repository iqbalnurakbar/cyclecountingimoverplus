<mvc:View
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
    xmlns:core="sap.ui.core"
    controllerName="cyclecountingimoverplus.ext.main.Main"
>
    <Page
        id="idMainPage"
        title="{i18n>MainTitle}"
        titleAlignment="Center"
    >
        <content>
            <f:Form
                id="idMainForm"
                editable="true"
                class="sapUiTinyMarginEnd"
            >
                <f:layout>
                    <f:ResponsiveGridLayout
                        id="idResponsiveGridLayout"
                        labelSpanXL="5"
                        labelSpanL="5"
                        labelSpanM="5"
                        emptySpanXL="1"
                        emptySpanL="1"
                        emptySpanM="1"
                        columnsXL="3"
                        columnsL="3"
                        columnsM="2"
                        class="sapUiTinyMarginEnd"
                    />
                </f:layout>
                <f:formContainers>
                    <!-- Left Column -->
                    <f:FormContainer id="idLeftColumnFormContainer">
                        <f:formElements>
                            <f:FormElement
                                id="idLocationFormElement"
                                label="{i18n>Location}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idLocationInput"
                                        maxLength="4"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idItennrFormElement"
                                label="{i18n>Itennr}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idItennrInput"
                                        maxLength="40"
                                        required="true"
                                        change="onInputChange"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idHandingUnitFormElement"
                                label="{i18n>HandingUnit}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idHandingUnitInput"
                                        maxLength="40"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idCountedQuantityFormElement"
                                label="{i18n>CountedQuantity}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idCountedQuantityInput"
                                        type="Number"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idBatchFormElement"
                                label="{i18n>Batch}"
                            >
                                <f:fields>
                                    <Input
                                        id="idBatchInput"
                                        maxLength="10"
                                        change="onInputChange"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idStockCategoryFormElement"
                                label="{i18n>StockCategory}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idStockCategoryInput"
                                        maxLength="1"
                                        change="onInputChange"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                        </f:formElements>
                    </f:FormContainer>

                    <!-- Middle Column -->
                    <f:FormContainer id="idMiddleColumnFormContainer">
                        <f:formElements>
                            <f:FormElement
                                id="idSpecialStockIndicatorFormElement"
                                label="{i18n>SpecialStockIndicator}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idSpecialStockIndicatorInput"
                                        maxLength="1"
                                        change="onInputChange"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idSpecialStockNumberFormElement"
                                label="{i18n>SpecialStockNumber}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idSpecialStockNumberInput"
                                        maxLength="16"
                                        change="onInputChange"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idSAPQuantityFormElement"
                                label="{i18n>SAPQuantity}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idSAPQuantityInput"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idStorageTypeFormElement"
                                label="{i18n>StorageType}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idStorageTypeInput"
                                        maxLength="4"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idDescriptionFormElement"
                                label="{i18n>Description}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idDescriptionInput"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idMaterialTypeFormElement"
                                label="{i18n>PartType}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idMaterialTypeInput"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idButtonFormElement"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <HBox
                                        id="idButtonHBox"
                                        justifyContent="Center"
                                        width="100%"
                                        class="sapUiTinyMarginEnd"
                                    >
                                        <Button
                                            id="idSaveWithoutSubmitButton"
                                            icon="sap-icon://drill-down"
                                            press="onButtonSaveWithoutSubmitPress"
                                            class="sapUiSmallMargin"
                                        />
                                        <Button
                                            id="idSaveButton"
                                            text="Save"
                                            type="Emphasized"
                                            press="onSaveButtonPress"
                                            class="sapUiSmallMargin"
                                        />
                                    </HBox>
                                </f:fields>
                            </f:FormElement>
                        </f:formElements>
                    </f:FormContainer>

                    <!-- Right Column -->
                    <f:FormContainer id="idRightColumnFormContainer">
                        <f:formElements>
                            <f:FormElement
                                id="idStandardCostFormElement"
                                label="{i18n>StandardCost}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idStandardCostInput"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idDesignGroupFormElement"
                                label="{i18n>DesignGroup}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <Input
                                        id="idDesignGroupInput"
                                        editable="false"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idGRNDateFormElement"
                                label="{i18n>GRNDate}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <DatePicker
                                        id="idGRNDatePicker"
                                        displayFormat="yyyy/MM/dd"
                                        width="100%"
                                    />
                                </f:fields>
                            </f:FormElement>
                            <f:FormElement
                                id="idProblemFormElement"
                                label="{i18n>Problem}"
                                class="sapUiTinyMarginEnd"
                            >
                                <f:fields>
                                    <ComboBox
                                        id="idProblemVhComboBox"
                                        width="100%"
                                        items="{/problem_vh}"
                                        showSecondaryValues="true"
                                    >
                                        <core:ListItem
                                            id="idZrsnCodeListItem"
                                            key="{ZrsnCode}"
                                            text="{ZrsnCode}"
                                            additionalText="{= ${ZdefTy} + ' - ' + ${ZrsnDesc} }"
                                        />
                                    </ComboBox>
                                </f:fields>
                            </f:FormElement>
                        </f:formElements>
                    </f:FormContainer>
                </f:formContainers>
            </f:Form>
        </content>
    </Page>
</mvc:View>
